# Test Environment Configuration
# This file is used for E2E testing

# Database - Using local PostgreSQL database
DATABASE_URL="postgresql://postgres:ake4112@localhost:5432/jobboardapi?schema=public"

# JWT
JWT_SECRET="test-jwt-secret-for-e2e-testing-only-not-for-production"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_SECRET="test-refresh-token-secret-for-e2e-testing"
REFRESH_TOKEN_EXPIRES_IN="7d"

# Application
PORT=3001
NODE_ENV="test"
API_PREFIX="api/v1"
APP_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:3002"

# CORS
CORS_ORIGIN="http://localhost:3002,http://localhost:3001"

# Rate Limiting (More permissive for testing)
RATE_LIMIT_TTL=900
RATE_LIMIT_MAX=1000

# Logging
LOG_LEVEL="error"

# Email Configuration (Use mock for testing)
EMAIL_PROVIDER="nodemailer"
EMAIL_FROM="test@jobboard-test.com"
EMAIL_FROM_NAME="Job Board Test"

# Mock SMTP Configuration
SMTP_HOST="smtp.ethereal.email"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="test@example.com"
SMTP_PASSWORD="test-password"

# Storage (Use test directory)
STORAGE_DIR="./test-storage"
MAX_FILE_SIZE=5242880

# File Storage
STORAGE_PROVIDER="local"
UPLOAD_PATH="./test-uploads"

# AWS S3 (Not used in testing)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
AWS_REGION="us-east-1"

# Redis (Cache & Queue) - Using Docker test instance (port 6380)
REDIS_HOST="localhost"
REDIS_PORT=6380
REDIS_PASSWORD=""
REDIS_DB=0
